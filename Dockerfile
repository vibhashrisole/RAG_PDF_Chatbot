# ==========================================
# Base Image
# ==========================================

FROM python:3.12-slim

# ==========================================
# Working Directory
# ==========================================

WORKDIR /app

# ==========================================
# Copy Requirements
# ==========================================

COPY requirements.txt .

# ==========================================
# Install Python Packages
# ==========================================

RUN pip install --no-cache-dir -r requirements.txt

# ==========================================
# Copy Project Files
# ==========================================

COPY . .

# ==========================================
# Expose FastAPI Port
# ==========================================

EXPOSE 8000

# ==========================================
# Run FastAPI Application
# ==========================================

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]